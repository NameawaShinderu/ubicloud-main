puts "   • Server logs: ssh root@#{hostname} 'journalctl -f'"
puts "   • SPDK status: ssh root@#{hostname} 'systemctl status spdk-*'"
puts "   • UbiCloud logs: docker-compose -f demo/docker-compose.yml logs -f"
puts ""
puts "🎉 Welcome to your private cloud!"
